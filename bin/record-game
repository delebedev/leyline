#!/usr/bin/env python3
"""
Autoplay orchestrator — spawns Claude agents to play MTGA bot matches,
monitors progress with a watchdog, collects transcripts and metrics,
runs analyst after completion.

Usage:
    bin/record-game --games 3          # run 3 games
    bin/record-game --games 10         # run 10 with gate after 3
    bin/record-game --games 3 --model sonnet  # use specific model
"""

import argparse
import json
import os
import shutil
import signal
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
PROMPT_FILE = ROOT / "docs" / "autoplay" / "play-game.md"
ANALYST_PROMPT = ROOT / "docs" / "autoplay" / "analyze-gameplay.md"
RETRO_TMP = Path("/tmp/agent-retro.md")
SCRY = str(ROOT / "bin" / "scry")
ARENA = str(ROOT / "bin" / "arena")

# Watchdog config
WATCHDOG_INTERVAL = 10          # seconds between checks
STUCK_TIMEOUT = 90              # seconds of no gsId change → kill
MAX_GAME_TIME = 600             # 10 minutes absolute max per game
OUTPUT_TOKEN_CAP = 200_000      # kill if agent produces this many output tokens


def log(msg: str) -> None:
    ts = datetime.now().strftime("%H:%M:%S")
    print(f"[{ts}] {msg}", flush=True)


def scry_state() -> dict | None:
    """Run bin/scry state and return parsed JSON, or None on failure."""
    try:
        r = subprocess.run(
            [SCRY, "state"],
            capture_output=True, text=True, timeout=10, cwd=str(ROOT),
        )
        if r.returncode == 0 and r.stdout.strip():
            return json.loads(r.stdout)
    except Exception:
        pass
    return None


def arena_cmd(args: list[str], timeout: int = 15) -> subprocess.CompletedProcess:
    """Run an arena command."""
    return subprocess.run(
        [ARENA] + args,
        capture_output=True, text=True, timeout=timeout, cwd=str(ROOT),
    )


def preflight() -> bool:
    """Check server + client are running, scry responds."""
    log("Pre-flight checks...")

    # Check scry responds
    state = scry_state()
    if state is None:
        log("FAIL: scry state returned nothing. Is Player.log accessible?")
        return False
    log(f"  scry: OK (scene={state.get('scene', {}).get('current', '?')})")

    # Check MTGA window exists
    r = arena_cmd(["ocr", "--find", "Home"])
    if r.returncode != 0:
        # Not on home — check if any MTGA window exists
        r2 = arena_cmd(["ocr"])
        if r2.returncode != 0:
            log("FAIL: no MTGA window found")
            return False
        log("  MTGA window: OK (not on Home screen — agent will handle)")
    else:
        log("  MTGA window: OK (Home screen)")

    # Auto-hide dock
    subprocess.run(
        ["osascript", "-e",
         'tell application "System Events" to set autohide of dock preferences to true'],
        capture_output=True, timeout=5,
    )
    log("  dock: auto-hidden")

    log("Pre-flight passed")
    return True


def extract_metrics(transcript_path: Path) -> dict:
    """Extract metrics from stream-json transcript."""
    metrics = {
        "tool_calls": 0,
        "screenshots": 0,
        "ocr_calls": 0,
        "scry_calls": 0,
        "blind_clicks_888": 0,
        "drag_calls": 0,
        "total_input_tokens": 0,
        "total_output_tokens": 0,
        "total_cost_usd": None,
        "duration_ms": 0,
        "num_turns": 0,
    }

    try:
        with open(transcript_path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue

                t = obj.get("type", "")

                if t == "result":
                    metrics["total_cost_usd"] = obj.get("total_cost_usd")
                    metrics["duration_ms"] = obj.get("duration_ms", 0)
                    metrics["num_turns"] = obj.get("num_turns", 0)
                    usage = obj.get("usage", {})
                    metrics["total_input_tokens"] = (
                        usage.get("input_tokens", 0)
                        + usage.get("cache_read_input_tokens", 0)
                        + usage.get("cache_creation_input_tokens", 0)
                    )
                    metrics["total_output_tokens"] = usage.get("output_tokens", 0)

                if t == "assistant":
                    msg = obj.get("message", {})
                    for block in msg.get("content", []):
                        if block.get("type") == "tool_use":
                            metrics["tool_calls"] += 1
                            inp = block.get("input", {})
                            cmd = inp.get("command", "")

                            if "arena capture" in cmd:
                                metrics["screenshots"] += 1
                            if "arena ocr" in cmd:
                                metrics["ocr_calls"] += 1
                            if "scry state" in cmd or "scry" in cmd:
                                metrics["scry_calls"] += 1
                            if "888,504" in cmd or "889,504" in cmd:
                                metrics["blind_clicks_888"] += 1
                            if "arena drag" in cmd:
                                metrics["drag_calls"] += 1
    except Exception as e:
        log(f"  metrics extraction error: {e}")

    return metrics


def parse_output_tokens_live(transcript_path: Path) -> int:
    """Quick scan of transcript for output token count from result line."""
    try:
        with open(transcript_path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                    if obj.get("type") == "result":
                        return obj.get("usage", {}).get("output_tokens", 0)
                except Exception:
                    pass
    except Exception:
        pass
    return 0


def start_video(video_path: Path) -> subprocess.Popen | None:
    """Start screen recording via ffmpeg. Returns process or None on failure."""
    try:
        proc = subprocess.Popen(
            [
                "ffmpeg", "-f", "avfoundation",
                "-framerate", "10", "-capture_cursor", "0",
                "-i", "0:none",
                "-c:v", "libx264", "-preset", "ultrafast", "-crf", "30",
                str(video_path), "-y",
            ],
            stdin=subprocess.PIPE,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return proc
    except Exception as e:
        log(f"  video recording failed to start: {e}")
        return None


def stop_video(proc: subprocess.Popen | None) -> None:
    """Stop ffmpeg recording gracefully."""
    if proc is None or proc.poll() is not None:
        return
    try:
        proc.stdin.write(b"q")
        proc.stdin.flush()
        proc.wait(timeout=5)
    except Exception:
        proc.terminate()
        try:
            proc.wait(timeout=3)
        except Exception:
            proc.kill()


def run_game(game_num: int, batch_dir: Path, model: str, record_video: bool = False) -> dict:
    """Run a single game. Returns metrics dict."""
    run_dir = batch_dir / f"run-{game_num}"
    run_dir.mkdir(parents=True, exist_ok=True)
    transcript_path = run_dir / "transcript.jsonl"

    log(f"=== Game {game_num} ===")

    # Read system prompt
    prompt_text = PROMPT_FILE.read_text()

    # Clean up old retro
    if RETRO_TMP.exists():
        RETRO_TMP.unlink()

    # Start video recording if enabled
    video_proc = None
    video_path = run_dir / "gameplay.mp4"
    if record_video:
        video_proc = start_video(video_path)
        if video_proc:
            log(f"  video recording started → {video_path.name}")

    # Record starting gsId so we can track delta (Player.log accumulates)
    start_state = scry_state()
    starting_gsid = None
    if start_state:
        starting_gsid = start_state.get("game_state_id")
    log(f"  starting gsId={starting_gsid}")

    # Spawn player agent
    cmd = [
        "claude", "-p",
        f"You are game {game_num}. Follow the system prompt instructions exactly. "
        f"Navigate to a bot match and play 5 turns.",
        "--system-prompt", prompt_text,
        "--model", model,
        "--output-format", "stream-json",
        "--verbose",
        "--dangerously-skip-permissions",
        "--disable-slash-commands",
        "--max-budget-usd", "3.00",
    ]

    log(f"  spawning agent (model={model})...")
    with open(transcript_path, "w") as transcript_f:
        proc = subprocess.Popen(
            cmd,
            stdout=transcript_f,
            stderr=subprocess.PIPE,
            cwd=str(ROOT),
        )

    # Watchdog loop
    start_time = time.time()
    last_gsid = starting_gsid
    last_gsid_time = start_time
    game_entered = False  # True once gsId changes from starting value
    kill_reason = None
    game_turns_reached = 0

    while proc.poll() is None:
        time.sleep(WATCHDOG_INTERVAL)
        elapsed = time.time() - start_time

        # Absolute timeout
        if elapsed > MAX_GAME_TIME:
            kill_reason = f"absolute timeout ({MAX_GAME_TIME}s)"
            break

        # Check game state via scry
        state = scry_state()

        gsid = None
        turn = 0
        if state:
            gsid = state.get("game_state_id")
            ti = state.get("turn_info") or {}
            raw_turn = ti.get("turn_number") if isinstance(ti, dict) else None
            turn = raw_turn if raw_turn is not None else 0

        if turn > game_turns_reached:
            game_turns_reached = turn

        # Track whether we've entered a new game
        if gsid is not None and gsid != starting_gsid:
            game_entered = True

        # gsId stuck detection — only once we've entered a game and gsId stops advancing
        if game_entered and gsid is not None:
            if gsid != last_gsid:
                last_gsid = gsid
                last_gsid_time = time.time()
            elif time.time() - last_gsid_time > STUCK_TIMEOUT:
                kill_reason = f"stuck (gsId={gsid} unchanged for {STUCK_TIMEOUT}s)"
                break

        # Log progress
        scene = state.get("scene", {}).get("current", "?") if state else "?"
        log(f"  [{elapsed:.0f}s] turn={turn} gsId={gsid} scene={scene}")

    # Kill if needed
    if kill_reason and proc.poll() is None:
        log(f"  KILLING agent: {kill_reason}")
        proc.send_signal(signal.SIGTERM)
        try:
            proc.wait(timeout=10)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait()
    elif proc.poll() is None:
        # Shouldn't happen but be safe
        proc.wait(timeout=30)

    exit_code = proc.returncode
    elapsed = time.time() - start_time
    log(f"  agent exited (code={exit_code}, {elapsed:.0f}s)")

    # Stop video recording
    stop_video(video_proc)
    if video_proc and video_path.exists():
        size_mb = video_path.stat().st_size / (1024 * 1024)
        log(f"  video: {video_path.name} ({size_mb:.1f} MB)")

    # Collect retro
    retro_dest = run_dir / "retro.md"
    if RETRO_TMP.exists():
        shutil.copy2(RETRO_TMP, retro_dest)
        log(f"  retro collected")
    else:
        retro_dest.write_text("# Agent Retro\n\nNo retro written by agent.\n")
        log(f"  no retro written by agent")

    # Extract metrics
    metrics = extract_metrics(transcript_path)
    metrics["game_num"] = game_num
    metrics["turns_reached"] = game_turns_reached
    metrics["kill_reason"] = kill_reason
    metrics["exit_code"] = exit_code
    metrics["wall_time_s"] = round(elapsed, 1)

    metrics_path = run_dir / "metrics.json"
    metrics_path.write_text(json.dumps(metrics, indent=2))
    log(f"  metrics: turns={game_turns_reached} tools={metrics['tool_calls']} "
        f"screenshots={metrics['screenshots']} cost=${metrics.get('total_cost_usd') or '?'}")

    # Post-game cleanup: concede if still in game, dismiss result, navigate to home
    time.sleep(3)
    _cleanup_game()

    return metrics


def _cleanup_game():
    """Concede if in-game, dismiss result screen, navigate to home."""
    # Check if we're still in a game
    state = scry_state()
    scene = state.get("scene", {}).get("current") if state else None

    if scene == "InGame" or (state and state.get("turn_info")):
        log("  still in game — conceding...")
        arena_cmd(["click", "940,42"])  # cog icon
        time.sleep(1)
        arena_cmd(["click", "Concede", "--retry", "3"])
        time.sleep(3)

    # Dismiss result/defeat/victory screens
    for _ in range(4):
        arena_cmd(["click", "480,300"])
        time.sleep(2)

    # Check if we're back at home
    time.sleep(2)
    r = arena_cmd(["ocr", "--find", "Home"])
    if r.returncode == 0:
        log("  back at Home screen")
    else:
        # Mastery Pass modal or other overlay — click Home nav (top-left)
        arena_cmd(["click", "40,25"])
        time.sleep(2)
        r = arena_cmd(["ocr", "--find", "Home"])
        if r.returncode == 0:
            log("  back at Home screen (after Home nav click)")
        else:
            # Try clicking center to dismiss
            arena_cmd(["click", "480,300"])
            time.sleep(2)
            r = arena_cmd(["ocr", "--find", "Home"])
            if r.returncode == 0:
                log("  back at Home screen (after center click)")
            else:
                log("  not at Home — next agent will handle navigation")


def evaluate_gate(metrics_list: list[dict]) -> bool:
    """After 3 games, decide if we continue."""
    reached_5 = sum(1 for m in metrics_list if m.get("turns_reached", 0) >= 5)
    total = len(metrics_list)
    log(f"=== GATE: {reached_5}/{total} games reached turn 5 ===")

    if reached_5 == 0:
        log("GATE FAILED: 0 games reached turn 5. Stopping batch.")
        return False

    log(f"GATE PASSED: {reached_5}/{total} succeeded. Continuing.")
    return True


def run_analyst(batch_dir: Path, model: str) -> None:
    """Run analyst agent on all transcripts."""
    log("=== Running Analyst ===")

    analyst_prompt = ANALYST_PROMPT.read_text()

    # Build file list for analyst
    run_dirs = sorted(batch_dir.glob("run-*"))
    file_list = []
    for rd in run_dirs:
        t = rd / "transcript.jsonl"
        r = rd / "retro.md"
        m = rd / "metrics.json"
        if t.exists():
            file_list.append(f"Transcript: {t}")
        if r.exists():
            file_list.append(f"Retro: {r}")
        if m.exists():
            file_list.append(f"Metrics: {m}")

    full_prompt = f"""{analyst_prompt}

## Files to Analyze

{chr(10).join(file_list)}

Read each file listed above. Write your report to: {batch_dir}/report.md
Write/append refinements to: {batch_dir}/refinements.md
"""

    report_path = batch_dir / "report.md"
    refinements_path = batch_dir / "refinements.md"

    cmd = [
        "claude", "-p",
        full_prompt,
        "--model", model,
        "--dangerously-skip-permissions",
        "--max-budget-usd", "2.00",
    ]

    log(f"  spawning analyst (model={model})...")
    r = subprocess.run(
        cmd,
        capture_output=True, text=True, timeout=600, cwd=str(ROOT),
    )

    if r.returncode == 0:
        log(f"  analyst done")
    else:
        log(f"  analyst failed (code={r.returncode})")
        if r.stderr:
            log(f"  stderr: {r.stderr[:200]}")

    # Print report summary if it exists
    if report_path.exists():
        log(f"  report: {report_path}")
        # Print first 20 lines
        lines = report_path.read_text().splitlines()[:20]
        for line in lines:
            print(f"    {line}")
    else:
        log("  no report written")

    if refinements_path.exists():
        log(f"  refinements: {refinements_path}")


def main():
    parser = argparse.ArgumentParser(description="Autoplay orchestrator")
    parser.add_argument("--games", type=int, default=3, help="Number of games to play")
    parser.add_argument("--model", default="sonnet", help="Claude model for player agent")
    parser.add_argument("--analyst-model", default="sonnet", help="Claude model for analyst")
    parser.add_argument("--skip-preflight", action="store_true", help="Skip pre-flight checks")
    parser.add_argument("--record-video", action="store_true", help="Record screen video per game")
    args = parser.parse_args()

    # Create batch directory
    ts = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
    batch_dir = ROOT / "docs" / "retro" / "autoplay" / f"batch-{ts}"
    batch_dir.mkdir(parents=True, exist_ok=True)
    log(f"Batch dir: {batch_dir}")

    # Pre-flight
    if not args.skip_preflight:
        if not preflight():
            sys.exit(1)

    all_metrics = []
    gate_checked = False

    for i in range(1, args.games + 1):
        metrics = run_game(i, batch_dir, args.model, record_video=args.record_video)
        all_metrics.append(metrics)

        # Gate check after 3 games
        if i == 3 and args.games > 3 and not gate_checked:
            gate_checked = True
            if not evaluate_gate(all_metrics):
                break

    # Write summary metrics
    summary_path = batch_dir / "summary.json"
    summary_path.write_text(json.dumps(all_metrics, indent=2))
    log(f"Summary: {summary_path}")

    # Run analyst
    run_analyst(batch_dir, args.analyst_model)

    # Final summary
    log("=== BATCH COMPLETE ===")
    total_games = len(all_metrics)
    reached_5 = sum(1 for m in all_metrics if m.get("turns_reached", 0) >= 5)
    total_cost = sum(m.get("total_cost_usd", 0) or 0 for m in all_metrics)
    total_tools = sum(m.get("tool_calls", 0) for m in all_metrics)
    total_screenshots = sum(m.get("screenshots", 0) for m in all_metrics)
    log(f"  games: {total_games}")
    log(f"  reached turn 5: {reached_5}/{total_games}")
    log(f"  total cost: ${total_cost:.2f}")
    log(f"  total tool calls: {total_tools}")
    log(f"  total screenshots: {total_screenshots}")
    log(f"  report: {batch_dir / 'report.md'}")


if __name__ == "__main__":
    main()
